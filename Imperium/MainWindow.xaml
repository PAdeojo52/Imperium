<mah:MetroWindow x:Class="Imperium.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="IMPERIVM" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="False"
        BorderThickness="0"
        Background="{StaticResource BgDeepBrush}">

    <Grid>
        <!-- Background gradient overlay -->
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.4" RadiusX="0.8" RadiusY="0.8">
                    <GradientStop Color="#1A1A2E" Offset="0"/>
                    <GradientStop Color="#0F0F23" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Subtle decorative line -->
        <Rectangle Height="1" VerticalAlignment="Top" Margin="0,200,0,0" Opacity="0.3">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#FFD700" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Center content -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">

            <!-- Title -->
            <TextBlock Text="IMPERIVM"
                       Style="{StaticResource TitleStyle}"
                       FontSize="72"
                       Margin="0,0,0,4"/>

            <TextBlock Text="The Ashen Arena"
                       Style="{StaticResource SubtitleStyle}"
                       FontSize="16"
                       Margin="0,0,0,50"/>

            <!-- Menu Buttons -->
            <Button Content="Start New Game" 
                    Style="{StaticResource MenuButtonStyle}"
                    Click="StartNewGame_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Play" Width="18" Height="18" 
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding}" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Load Game" 
                    Style="{StaticResource MenuButtonStyle}"
                    Click="LoadGame_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="18" Height="18" 
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding}" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Options" 
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Options_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" 
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding}" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Exit" 
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Exit_Click">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="18" Height="18" 
                                                        VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding}" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!-- Version tag -->
        <TextBlock Text="Version 1.0 — The Ashen Arena"
                   FontSize="12" Foreground="{StaticResource TextDimBrush}"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,20,12"/>
    </Grid>
</mah:MetroWindow>
