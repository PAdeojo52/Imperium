<Window x:Class="Imperium.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Imperium"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1600">
    <Grid>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden">
            <Frame.Content>
                <Grid>

                    <!-- Background Remeber to add pic if needed-->
                    <Grid.Background>
                        <ImageBrush  Stretch="UniformToFill"/>
                    </Grid.Background>

                    <!-- Overlay -->
                    <Rectangle Fill="#AA000000" />

                    <!-- Center Content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Title -->
                        <TextBlock Text="IMPERIVM"
                               FontSize="72"
                               FontWeight="Bold"
                               Foreground="Gold"
                               FontFamily="Georgia"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                        <!-- Buttons -->
                        <StackPanel Width="300">
                            <Button Content="▶ Start New Game" Height="50" FontSize="18"
                                Click="StartNewGame_Click"/>
                            <Button Content="📂 Load Game" Height="50" FontSize="18"
                                Click="LoadGame_Click"/>
                            <Button Content="⚙ Options" Height="50" FontSize="18"
                                Click="Options_Click"/>
                            <Button Content="❌ Exit" Height="50" FontSize="18"
                                Click="Exit_Click"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Bottom Right -->
                    <TextBlock Text="Version 1.0 - The Ashen Arena"
                           FontSize="14"
                           Foreground="White"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0 0 20 10"/>

                </Grid>
            </Frame.Content>
        </Frame>
    </Grid>
</Window>
