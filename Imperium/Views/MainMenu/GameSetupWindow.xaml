<mah:MetroWindow x:Class="Imperium.Views.MainMenu.GameSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="IMPERIVM — New Game" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="False" BorderThickness="0"
        Background="{StaticResource BgDeepBrush}">

    <Grid>
        <!-- Centered setup panel -->
        <Border Style="{StaticResource CardStyle}" 
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="500" Padding="40">
            <StackPanel>

                <!-- Header -->
                <TextBlock Text="NEW GAME" Style="{StaticResource PageHeaderStyle}" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Set up your save file and choose your difficulty."
                           Style="{StaticResource SubtitleStyle}" Margin="0,0,0,32"/>

                <!-- Save File Name -->
                <TextBlock Text="SAVE FILE NAME" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBox x:Name="SaveFileNameTextBox" 
                         Style="{StaticResource DarkTextBoxStyle}"
                         Margin="0,0,0,24"/>

                <!-- Difficulty -->
                <TextBlock Text="DIFFICULTY" Style="{StaticResource SectionHeaderStyle}"/>
                <UniformGrid Columns="3" Margin="0,0,0,32">
                    <!-- Easy -->
                    <Border x:Name="DiffEasy" Style="{StaticResource SelectableCardStyle}"
                            MouseLeftButtonDown="DiffEasy_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Shield" Width="24" Height="24" 
                                                        Foreground="{StaticResource AccentBlueBrush}"
                                                        HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Easy" FontSize="14" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Forgiving combat" FontSize="11" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Medium -->
                    <Border x:Name="DiffMedium" Style="{StaticResource SelectableCardStyle}"
                            BorderBrush="{StaticResource AccentGoldBrush}"
                            MouseLeftButtonDown="DiffMedium_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Sword" Width="24" Height="24" 
                                                        Foreground="{StaticResource AccentGoldBrush}"
                                                        HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Medium" FontSize="14" FontWeight="SemiBold" 
                                       Foreground="{StaticResource AccentGoldBrush}" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Balanced challenge" FontSize="11" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Hard -->
                    <Border x:Name="DiffHard" Style="{StaticResource SelectableCardStyle}"
                            MouseLeftButtonDown="DiffHard_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Skull" Width="24" Height="24" 
                                                        Foreground="#E53935"
                                                        HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Hard" FontSize="14" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Permadeath active" FontSize="11" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Back" 
                            Style="{StaticResource GhostButtonStyle}"
                            Click="BackButton_Click" HorizontalAlignment="Left"/>
                    <Button Grid.Column="1" Content="Next" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="NextButton_Click" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
