<Page x:Class="Imperium.Views.MainMenu.GameSetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Imperium.Views.MainMenu"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameSetupPage">

    <Grid>
        <Grid.Background>
            <ImageBrush Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Overlay -->
        <Rectangle Fill="#AA000000"/>

        <!-- Setup Panel -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">

            <TextBlock Text="New Game Setup" 
                       FontSize="36" 
                       FontWeight="Bold" 
                       Foreground="Gold" 
                       TextAlignment="Center" 
                       Margin="0 0 0 20"/>

            <!-- Save File Name -->
            <StackPanel>
                <TextBlock Text="Save File Name:" FontSize="18" Foreground="White"/>
                <TextBox x:Name="SaveFileNameTextBox" Height="30" FontSize="16"/>
            </StackPanel>

            <!-- Difficulty -->
            <StackPanel>
                <TextBlock Text="Select Difficulty:" FontSize="18" Foreground="White"/>
                <ComboBox x:Name="DifficultyComboBox" Height="30" FontSize="16" SelectedIndex="1">
                    <ComboBoxItem Content="Easy"/>
                    <ComboBoxItem Content="Medium"/>
                    <ComboBoxItem Content="Hard"/>
                </ComboBox>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                <Button Content="← Back" Width="100" Click="BackButton_Click"/>
                <Button Content="Next →" Width="100" Click="NextButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
