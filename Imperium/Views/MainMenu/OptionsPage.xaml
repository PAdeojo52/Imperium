<mah:MetroWindow x:Class="Imperium.Views.MainMenu.OptionsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="IMPERIVM — Options" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ShowTitleBar="False" BorderThickness="0"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeepBrush}">

    <Grid>
        <Border Style="{StaticResource CardStyle}" Margin="20" Padding="32">
            <StackPanel>
                <TextBlock Text="OPTIONS" Style="{StaticResource PageHeaderStyle}" 
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Audio -->
                <TextBlock Text="AUDIO" Style="{StaticResource SectionHeaderStyle}"/>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Music Volume" Style="{StaticResource LabelStyle}" 
                               VerticalAlignment="Center"/>
                    <Slider Minimum="0" Maximum="100" Value="75" 
                            HorizontalAlignment="Right" Width="200" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="Sound Effects" Style="{StaticResource LabelStyle}" 
                               VerticalAlignment="Center"/>
                    <Slider Minimum="0" Maximum="100" Value="100" 
                            HorizontalAlignment="Right" Width="200" VerticalAlignment="Center"/>
                </Grid>

                <!-- Display -->
                <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeaderStyle}"/>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Fullscreen" Style="{StaticResource LabelStyle}" 
                               VerticalAlignment="Center"/>
                    <mah:ToggleSwitch HorizontalAlignment="Right" IsOn="False"/>
                </Grid>

                <Grid Margin="0,0,0,32">
                    <TextBlock Text="Show Tooltips" Style="{StaticResource LabelStyle}" 
                               VerticalAlignment="Center"/>
                    <mah:ToggleSwitch HorizontalAlignment="Right" IsOn="True"/>
                </Grid>

                <!-- Close -->
                <Button Content="Close" Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Center" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
