<UserControl x:Class="Imperium.Views.CharacterCreation.StepReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel MaxWidth="600" HorizontalAlignment="Center">
            <TextBlock Text="REVIEW YOUR GLADIATOR" Style="{StaticResource PageHeaderStyle}" 
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Confirm your choices. Once you enter the arena, there's no turning back."
                       Style="{StaticResource SubtitleStyle}" Margin="0,0,0,32"/>

            <!-- Identity -->
            <Border Background="{StaticResource BgInputBrush}" CornerRadius="8" 
                    Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="60" Height="60" CornerRadius="30" 
                            Background="#2E4057" Margin="0,0,16,0">
                        <iconPacks:PackIconMaterial Kind="AccountCircle" 
                                                    Width="30" Height="30"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ReviewName" Text="Name" FontSize="22" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="ReviewRace" Text="Race" FontSize="14" 
                                       Foreground="{StaticResource AccentGoldBrush}"/>
                            <TextBlock Text="  •  " Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="ReviewClass" Text="Class" FontSize="14" 
                                       Foreground="{StaticResource AccentGoldBrush}"/>
                            <TextBlock Text="  •  " Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="ReviewPronouns" Text="Pronouns" FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats -->
            <Border Background="{StaticResource BgInputBrush}" CornerRadius="8" 
                    Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="ATTRIBUTES" Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="4" x:Name="StatsGrid">
                        <!-- Populated in code-behind -->
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Game Settings -->
            <Border Background="{StaticResource BgInputBrush}" CornerRadius="8" 
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="GAME SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Save File" Style="{StaticResource LabelStyle}"/>
                        <TextBlock x:Name="ReviewSaveName" Text="—" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Difficulty" Style="{StaticResource LabelStyle}"/>
                        <TextBlock x:Name="ReviewDifficulty" Text="—" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
