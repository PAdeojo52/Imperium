<UserControl x:Class="Imperium.Views.CharacterCreation.StepRaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Border Style="{StaticResource CardStyle}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                <TextBlock Text="CHOOSE YOUR RACE" Style="{StaticResource PageHeaderStyle}" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Your heritage shapes your strengths and how the world sees you."
                           Style="{StaticResource SubtitleStyle}"/>
            </StackPanel>

            <!-- Race selection grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Race cards list -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RaceList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SelectableCardStyle}" 
                                        MouseLeftButtonDown="RaceCard_Click" Tag="{Binding Name}">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="40" Height="40" CornerRadius="20" 
                                                Background="#2E4057" Margin="0,0,12,0">
                                            <iconPacks:PackIconMaterial Kind="AccountCircle" 
                                                                        Width="20" Height="20"
                                                                        Foreground="{StaticResource TextMutedBrush}"
                                                                        HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding ShortDesc}" FontSize="11" 
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Right: Selected race details -->
                <Border Grid.Column="1" Background="{StaticResource BgInputBrush}" 
                        CornerRadius="8" Padding="20" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="RaceDetailName" Text="Select a Race" 
                                   FontSize="20" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentGoldBrush}" 
                                   Margin="0,0,0,12"/>
                        <TextBlock x:Name="RaceDetailDesc" 
                                   Text="Choose a race from the list to see details." 
                                   Style="{StaticResource DescriptionStyle}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="STAT BONUSES" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="RaceDetailBonuses" Text="—" 
                                   FontSize="13" Foreground="{StaticResource AccentBlueBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
