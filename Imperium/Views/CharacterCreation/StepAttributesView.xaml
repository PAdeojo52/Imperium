<UserControl x:Class="Imperium.Views.CharacterCreation.StepAttributesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel MaxWidth="700" HorizontalAlignment="Center">
            <TextBlock Text="DISTRIBUTE ATTRIBUTES" Style="{StaticResource PageHeaderStyle}" 
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Spend 27 points across your stats. Each stat caps at 15."
                       Style="{StaticResource SubtitleStyle}" Margin="0,0,0,12"/>

            <!-- Points remaining -->
            <Border Background="#1E3A5F" CornerRadius="8" Padding="16" Margin="0,0,0,24" 
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Points Remaining: " FontSize="18" 
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PointsRemainingText" Text="27" FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource AccentGoldBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Stat Rows -->
            <StackPanel x:Name="StatRowsPanel">
                <!-- Rows are generated in code-behind for cleaner logic -->
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
