<UserControl x:Class="Imperium.Views.CharacterCreation.StepIdentityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel MaxWidth="500" HorizontalAlignment="Center">
            <TextBlock Text="WHO ARE YOU?" Style="{StaticResource PageHeaderStyle}" 
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Every gladiator has a name spoken by the crowd."
                       Style="{StaticResource SubtitleStyle}" Margin="0,0,0,40"/>

            <!-- First Name -->
            <TextBlock Text="FIRST NAME" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBox x:Name="FirstNameBox" Style="{StaticResource DarkTextBoxStyle}" 
                     Margin="0,0,0,20" TextChanged="NameChanged"/>

            <!-- Last Name -->
            <TextBlock Text="LAST NAME" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBox x:Name="LastNameBox" Style="{StaticResource DarkTextBoxStyle}" 
                     Margin="0,0,0,20" TextChanged="NameChanged"/>

            <!-- Pronouns -->
            <TextBlock Text="PRONOUNS" Style="{StaticResource SectionHeaderStyle}"/>
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border x:Name="PronounHe" Style="{StaticResource SelectableCardStyle}" 
                        BorderBrush="{StaticResource AccentGoldBrush}"
                        MouseLeftButtonDown="PronounHe_Click">
                    <TextBlock Text="He/Him" FontSize="13" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="PronounShe" Style="{StaticResource SelectableCardStyle}" 
                        MouseLeftButtonDown="PronounShe_Click">
                    <TextBlock Text="She/Her" FontSize="13" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="PronounThey" Style="{StaticResource SelectableCardStyle}" 
                        MouseLeftButtonDown="PronounThey_Click">
                    <TextBlock Text="They/Them" FontSize="13" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="PronounOther" Style="{StaticResource SelectableCardStyle}" 
                        MouseLeftButtonDown="PronounOther_Click">
                    <TextBlock Text="Other" FontSize="13" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Center"/>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>
