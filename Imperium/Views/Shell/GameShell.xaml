<mah:MetroWindow x:Class="Imperium.Views.Shell.GameShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:Imperium.Views.Shell"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="GameShell" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"         
        BorderThickness="1"
        Background="#1A1A2E">

    <mah:MetroWindow.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A4A"/>
                                <Setter Property="Foreground" Value="#CCDDEE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar button -->
        <Style x:Key="SidebarButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#2E4057"/>
            <Setter Property="Foreground" Value="#FFD700"/>
        </Style>

        <!-- Card panel style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#16213E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- Section header text -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Stat value text -->
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Stat label text -->
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#667788"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="58"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- Top date strip -->
            <RowDefinition Height="50"/>
            <!-- Content area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- LEFT SIDEBAR (spans both rows) -->
        <!-- ============================================================ -->
        <Border Grid.Column="0" Grid.RowSpan="2" 
                Background="#0F0F23"
                BorderBrush="#2A2A4A" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo/brand at top -->
                <Border DockPanel.Dock="Top" Height="50" 
                        BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
                    <TextBlock Text="I" FontSize="24" FontWeight="Bold" 
                               Foreground="#FFD700" FontFamily="Georgia"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Navigation buttons -->
                <StackPanel VerticalAlignment="Top" Margin="4,8">
                    <!-- Dashboard -->
                    <Button x:Name="NavDashboard" 
                            Style="{StaticResource SidebarButtonActiveStyle}"
                            Click="NavDashboard_Click"
                            ToolTip="Dashboard">
                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20"/>
                    </Button>

                    <!-- Character/Stats -->
                    <Button x:Name="NavCharacter"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavCharacter_Click"
                            ToolTip="Character">
                        <iconPacks:PackIconMaterial Kind="AccountCircle" Width="20" Height="20"/>
                    </Button>

                    <!-- Calendar/Schedule -->
                    <Button x:Name="NavCalendar"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavCalendar_Click"
                            ToolTip="Calendar">
                        <iconPacks:PackIconMaterial Kind="CalendarMonth" Width="20" Height="20"/>
                    </Button>

                    <!-- Arena/Combat -->
                    <Button x:Name="NavArena"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavArena_Click"
                            ToolTip="Arena">
                        <iconPacks:PackIconMaterial Kind="Sword" Width="20" Height="20"/>
                    </Button>

                    <!-- Inventory -->
                    <Button x:Name="NavInventory"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="NavInventory_Click"
                            ToolTip="Inventory">
                        <iconPacks:PackIconMaterial Kind="BagPersonal" Width="20" Height="20"/>
                    </Button>
                </StackPanel>

                <!-- Bottom section: Settings/Save -->
                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="4,0,4,8">
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="NavSettings_Click"
                            ToolTip="Settings">
                        <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Click="SaveGame_Click"
                            ToolTip="Save Game">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- TOP DATE STRIP -->
        <!-- ============================================================ -->
        <Border Grid.Column="1" Grid.Row="0" 
                Background="#0F0F23"
                BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Current Date -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="CalendarToday" 
                                                Width="16" Height="16" 
                                                Foreground="#FFD700" 
                                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CurrentDateText" 
                               Text="Day 1, Month 1, Year 1"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#EEEEFF" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Season Badge -->
                <Border Grid.Column="1" 
                        Background="#2E4057" CornerRadius="12" 
                        Padding="12,4" Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial x:Name="SeasonIcon" 
                                                    Kind="Snowflake" 
                                                    Width="14" Height="14"
                                                    Foreground="#4FC3F7" 
                                                    VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="SeasonText" 
                                   Text="Winter"
                                   FontSize="12" Foreground="#AABBCC" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Next Turn Button -->
                <Button Grid.Column="3" 
                        x:Name="NextTurnButton"
                        Click="NextTurn_Click"
                        Height="34" Padding="16,0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" 
                                    Background="#2E7D32" CornerRadius="6" 
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Play" 
                                                                Width="14" Height="14" 
                                                                Foreground="White" 
                                                                VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Next Turn" 
                                               FontSize="13" FontWeight="SemiBold" 
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#388E3C"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#1B5E20"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- MAIN CONTENT AREA -->
        <!-- ============================================================ -->
        <ContentControl Grid.Column="1" Grid.Row="1" 
                         x:Name="MainContent"
                         Margin="0"/>

    </Grid>
</mah:MetroWindow>

